# =========================================================================
# A11y-Agent Backend Environment Settings
# =========================================================================
# Copy this file to '.env' in this directory and populate with your settings.
# IMPORTANT: DO NOT commit your active '.env' file to public Git repositories!

# Google Gemini API Credentials
# Get your key at https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# Model Selection:
# - gemini-2.5-flash (Standard, fast & cost-efficient)
# - gemini-2.5-pro   (Pro tier, advanced contextual logic)
GEMINI_MODEL=gemini-2.5-pro
